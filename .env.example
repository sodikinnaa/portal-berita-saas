# Copy file ini ke .env.local untuk development lokal.
# Production/Docker sebaiknya set variable ini dari server/container runtime.

APP_ENV=development
DEBUG=true
ADDR=:8080
DATABASE_URL=postgres://portal:portal123@localhost:5432/portal_berita?sslmode=disable
UPLOAD_DIR=uploads
READ_TIMEOUT=60s
WRITE_TIMEOUT=120s
IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=10s
SESSION_TTL=24h
